@import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&family=Sora:wght@300;400;600;700&display=swap');
:root {
  --uv-r:#C8102E; --uv-b:#185FA5; --uv-g:#0F6E56;
  --gris:#5a5850; --gris-clar:#f8f7f5; --brd:#e0ddd6;
  --blanc:#fff; --txt:#1a1a18;
  --mono:'IBM Plex Mono',monospace; --sans:'Sora',sans-serif;
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:var(--sans);background:var(--gris-clar);color:var(--txt)}
.header{background:var(--uv-r)}
.header-inner{display:flex;align-items:center;justify-content:space-between;padding:11px 24px}
.logo-tan{font-size:20px;font-weight:700;color:#fff;letter-spacing:.06em;font-family:var(--mono)}
.logo-slpl{font-size:12px;color:rgba(255,255,255,.85);margin-left:10px}
.status{display:flex;align-items:center;gap:7px}
.dot{width:9px;height:9px;border-radius:50%;background:#aaa;transition:background .3s}
.dot.ok{background:#4CAF50}
.dot.err{background:#f44336}
.status-txt{font-size:12px;color:rgba(255,255,255,.85)}
.nav{background:rgba(0,0,0,.15);display:flex;padding:0 24px}
.nav-btn{background:none;border:none;color:rgba(255,255,255,.7);padding:10px 18px;cursor:pointer;font-size:13px;border-bottom:3px solid transparent;font-family:var(--sans);transition:all .2s}
.nav-btn:hover,.nav-btn.act{color:#fff;border-bottom-color:#fff}
.seccio{max-width:1080px;margin:24px auto;padding:0 16px;display:none}
.seccio.vis{display:block}
.mode-toggle{display:flex;gap:8px;margin-bottom:16px}
.mode-btn{padding:7px 20px;border:1.5px solid var(--brd);border-radius:20px;background:var(--blanc);cursor:pointer;font-size:13px;font-family:var(--sans);transition:all .2s}
.mode-btn.act{background:var(--uv-r);color:#fff;border-color:var(--uv-r)}
.mode-btn.act-b{background:var(--uv-b);color:#fff;border-color:var(--uv-b)}
.panells{display:grid;grid-template-columns:1fr 72px 1fr;background:var(--blanc);border:1px solid var(--brd);border-radius:10px;overflow:hidden;min-height:320px}
.panell-cap{padding:11px 15px;border-bottom:1px solid var(--brd);background:#fafafa;display:flex;justify-content:space-between;align-items:center}
.idioma{font-size:13px;font-weight:600}
.comptador,.temps{font-size:11px;color:var(--gris)}
.textarea{width:100%;border:none;outline:none;padding:15px;font-size:15px;line-height:1.65;resize:none;font-family:var(--sans);color:var(--txt);min-height:240px}
.textarea.traduit{background:#fafafa}
.panell-esquerre,.panell-dret{display:flex;flex-direction:column}
.central{display:flex;flex-direction:column;align-items:center;justify-content:center;border-left:1px solid var(--brd);border-right:1px solid var(--brd);background:#fafafa;gap:8px}
.btn-tradueix{background:var(--uv-r);color:#fff;border:none;border-radius:8px;padding:12px 8px;cursor:pointer;font-size:12px;font-weight:600;writing-mode:vertical-rl;min-height:90px;font-family:var(--sans);transition:opacity .2s}
.btn-tradueix:hover{opacity:.9}
.btn-tradueix:disabled{opacity:.45;cursor:not-allowed}
.btn-tradueix.blau{background:var(--uv-b)}
.accions{padding:8px 15px;display:flex;gap:7px;flex-wrap:wrap}
.btn-sec{padding:5px 13px;border:1px solid var(--brd);border-radius:5px;background:none;cursor:pointer;font-size:12px;color:var(--gris);font-family:var(--sans)}
.btn-sec:hover{background:var(--gris-clar)}
.btn-desa{padding:5px 15px;background:var(--uv-g);color:#fff;border:none;border-radius:5px;cursor:pointer;font-size:12px;font-weight:600;font-family:var(--sans)}
.dropzone{border:2px dashed var(--brd);border-radius:10px;padding:56px 32px;text-align:center;cursor:pointer;background:var(--blanc);transition:all .2s}
.dropzone:hover{border-color:var(--uv-r);background:#fff5f7}
.drop-icon{font-size:44px;margin-bottom:10px}
.drop-titol{font-size:17px;font-weight:600;margin-bottom:5px}
.drop-sub{font-size:12px;color:var(--gris)}
.progres-cont{margin-top:14px;display:none}
.progres-lbl{font-size:12px;color:var(--gris);margin-bottom:5px}
.progres-bar{background:var(--brd);border-radius:4px;height:5px;overflow:hidden}
.progres-fill{height:100%;background:var(--uv-r);animation:prog 2s ease-in-out infinite}
@keyframes prog{0%{width:0}50%{width:75%}100%{width:95%}}
.resultat-card{background:var(--blanc);border:1px solid var(--brd);border-radius:10px;padding:18px 22px;display:none;align-items:center;gap:14px;margin-top:14px}
.res-icona{font-size:34px}
.res-info{flex:1}
.res-nom{font-size:14px;font-weight:600}
.res-det{font-size:11px;color:var(--gris);margin-top:2px}
.btn-descarrega{background:var(--uv-b);color:#fff;border:none;border-radius:8px;padding:10px 20px;cursor:pointer;font-size:13px;font-weight:600;font-family:var(--sans)}
.btn-descarrega:hover{opacity:.9}
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}
.stat-card{background:var(--blanc);border:1px solid var(--brd);border-radius:10px;padding:22px;text-align:center}
.stat-lbl{font-size:11px;color:var(--gris);text-transform:uppercase;letter-spacing:.05em}
.stat-val{font-size:34px;font-weight:700;color:var(--uv-r);margin-top:6px;font-family:var(--mono)}
@media(max-width:680px){
  .panells{grid-template-columns:1fr}
  .central{border:none;border-top:1px solid var(--brd);border-bottom:1px solid var(--brd);padding:10px}
  .btn-tradueix{writing-mode:horizontal-tb;min-height:auto;width:100%}
  .stats-grid{grid-template-columns:1fr 1fr}
}
